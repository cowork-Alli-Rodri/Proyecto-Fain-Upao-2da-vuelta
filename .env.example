# ============================================================================
# Voto Informado UPAO — variables de entorno
# ============================================================================
# Copiar a `.env.local` para desarrollo y a Vercel Dashboard para producción.
# NUNCA commitear `.env.local` (está en .gitignore).
# ============================================================================

# ---------- Site ----------
# URL pública del despliegue. En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Supabase (local: auto-llenado por `supabase start`) ----------
# Public — expuestos al cliente (anon key tiene RLS aplicada)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — service role bypasses RLS, NUNCA expongas al cliente
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Supabase Auth providers (configurar en Supabase Dashboard) ----------
# Google OAuth — https://console.cloud.google.com/apis/credentials
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=

# Microsoft / Azure AD — https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
SUPABASE_AUTH_MICROSOFT_CLIENT_ID=
SUPABASE_AUTH_MICROSOFT_SECRET=

# ---------- Upstash Redis (rate limiting) ----------
# https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Cloudflare Turnstile (anti-bot) ----------
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------- JNE API ----------
# Base URL del servicio Voto Informado del JNE (no requiere clave)
JNE_API_BASE=https://web.jne.gob.pe/serviciovotoinformado

# ---------- Cron handlers ----------
# Secret compartido entre Vercel Cron y los handlers de /api/cron/*
# Rotar al menos una vez antes de producción
CRON_SECRET=local-dev-secret-change-me

# ---------- Sentry (observabilidad de errores) ----------
# https://sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---------- PostHog (analytics de producto, sin PII) ----------
# https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
